{
  "_comment": "Balance study: on clay, Ace (idx 4) vs Ace (idx 4). Side A (you) plays Topspin only, side B (opp) plays Flat only, both Slice on the return of serve. The objective rewards parameter sets where A's per-MATCH win rate is near 60% (topspin the slightly-better percentage play), with a sample-size penalty so a near-60% seen over too few matches does not score well. First server alternates by seed so the 60% reflects shot merit, not serve order. Copy to e.g. autotune.topspin.config.json and run: .venv-autotune/bin/python scripts/autotune/tune.py --config autotune.topspin.config.json . Every number here is editable.",

  "search_space": {
    "topspin_speed_mul":    { "min": 0.70, "max": 1.05 },
    "flat_speed_mul":       { "min": 0.90, "max": 1.10 },
    "slice_speed_mul":      { "min": 0.65, "max": 0.90 },
    "topspin_theta_min":    { "min": 6.0,  "max": 16.0 },
    "topspin_theta_max":    { "min": 24.0, "max": 42.0 },
    "flat_theta_max":       { "min": 10.0, "max": 22.0 },
    "topspin_rpm_base":     { "min": 1600, "max": 3000 },
    "topspin_rpm_slope":    { "min": 1600, "max": 3400 },
    "aero_cl_max":          { "min": 0.30, "max": 0.55 },
    "net_margin_drive":     { "min": 0.02, "max": 0.18 },
    "net_margin_control":   { "min": 0.12, "max": 0.42 },
    "rally_depth_min":      { "min": 3.5,  "max": 6.0 },
    "rally_depth_max":      { "min": 10.0, "max": 12.5 },
    "bounce_v_ref":         { "min": 5.0,  "max": 10.0 },
    "bounce_slope":         { "min": 0.005,"max": 0.02 },
    "bounce_min_frac":      { "min": 0.50, "max": 0.80 },
    "spin_bounce_vertical": { "min": 0.0,  "max": 0.01 }
  },

  "fixed_params": {},

  "fitness": [
    { "metric": "side_a_win_pct",  "target": 60, "robust": true, "z": 1.0, "weight": 1.0, "scale": 6.0 },
    { "metric": "avg_rally_shots", "min": 3,   "max": 11,   "weight": 0.3, "scale": 2.0 },
    { "metric": "winner_pct",      "min": 15,  "max": 45,   "weight": 0.2, "scale": 8.0 },
    { "metric": "unforced_pct",    "min": 25,  "max": 68,   "weight": 0.2, "scale": 8.0 },
    { "metric": "match_duration_s","min": 240, "max": 1200, "weight": 0.2, "scale": 120 }
  ],

  "run": {
    "n_trials": 200,
    "matches_per_trial": 48,
    "seed_base": 1000,
    "workers": 4,
    "games": 4,
    "max_steps_per_match": 600000,
    "sampler_seed": 42,
    "timeout_weight": 50.0,
    "max_consecutive_failures": 5,
    "matchups": [
      {
        "you": 4, "opp": 4, "surface": "clay", "difficulty": "normal",
        "force": { "a": "topspin", "b": "flat", "return": "slice", "alternate_server": true }
      }
    ]
  },

  "validation": {
    "top_k": 5,
    "seed_base": 100000,
    "matches_per_matchup": 120
  },

  "output_dir": "autotune_topspin_out"
}
